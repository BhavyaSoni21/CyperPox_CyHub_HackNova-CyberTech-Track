# ──────────────────────────────────────────────
# CyHub Backend — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────────

# ── Server ──────────────────────────────────
# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# Model path (relative to backend/)
MODEL_PATH=models/isolation_forest.pkl

# ── MongoDB (optional) ──────────────────────
# Leave MONGO_URI blank to fall back to in-memory storage + disk JSON
# The system is fully functional without MongoDB
MONGO_URI=
MONGODB_DB=cyhub

# ── HuggingFace Model Endpoints ─────────────
# M1 — Payload Attack model (injection / XSS / traversal)
HF_MODEL1_URL=https://bhavyasoni21-model1.hf.space/predict
HF_MODEL1_TIMEOUT=8.0

# M2 — Bot Detection model (automated scanners)
HF_MODEL2_URL=https://bhavyasoni21-model2.hf.space/predict
HF_MODEL2_TIMEOUT=8.0

# M3 — Traffic Anomaly model (RandomForest, 35 features)
HF_MODEL3_URL=https://bhavyasoni21-model3.hf.space/predict
HF_MODEL3_TIMEOUT=8.0

# M4 — URL Classifier (normal / adult / betting / malware / phishing / unknown)
HF_MODEL4_URL=https://bhavyasoni21-model4.hf.space/predict
HF_MODEL4_TIMEOUT=8.0

# Optional: HuggingFace API token (for private/gated spaces)
HF_API_TOKEN=

# ── Threat Intelligence Blocklists ──────────
# Set to true to load URLhaus / PhishTank / Spamhaus on startup (requires MongoDB)
LOAD_BLOCKLISTS_ON_STARTUP=true

# Override default feed URLs (optional)
# URLHAUS_API_URL=https://urlhaus.abuse.ch/downloads/csv_recent/
# PHISHTANK_API_URL=https://phishtank.com/phish_download.php
# SPAMHAUS_API_URL=https://www.spamhaus.org/drop/drop.txt

# ── Domain Intelligence ──────────────────────
# Additional domains to whitelist (comma-separated)
WHITELIST_DOMAINS=

# Domain cache TTL in seconds (default: 30 days)
DOMAIN_CACHE_TTL=2592000

# DNS lookup timeout in seconds
DNS_VALIDATION_TIMEOUT=5.0
